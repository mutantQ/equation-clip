{
  "train_data": "data/dataset/train_arxiv.json",
  "val_data": "data/dataset/val_arxiv.json",
  "test_data": "data/dataset/test_arxiv.json",
  "output_dir": "checkpoints/arxiv_run",
  "equation_encoder_type": "gnn",
  "equation_vocab_size": 5000,
  "equation_hidden_dim": 256,
  "equation_num_layers": 3,
  "text_encoder_type": "scibert",
  "text_model_name": "allenai/scibert_scivocab_uncased",
  "text_hidden_dim": 768,
  "freeze_text_layers": 6,
  "embedding_dim": 128,
  "projection_hidden_dim": 512,
  "dropout": 0.1,
  "temperature": 0.07,
  "learnable_temperature": true,
  "batch_size": 16,
  "num_epochs": 10,
  "learning_rate": 0.0001,
  "weight_decay": 0.01,
  "warmup_steps": 100,
  "eval_every_n_steps": 200,
  "save_every_n_epochs": 1,
  "mixed_precision": true,
  "num_workers": 4
}